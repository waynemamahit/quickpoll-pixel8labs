{
  "name": "quickpoll-pixel8labs",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.17.0"
  },
  "scripts": {
    "postinstall": "pnpm typecheck",
    "lint": "biome check --write",
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "pnpm build && node scripts/gen-wrangler.js local && wrangler dev --local",
    "preview:remote": "pnpm build && node scripts/gen-wrangler.js local && wrangler dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage --config vitest.config.ts && vitest run --config vitest.workers.config.ts",
    "test:out": "vitest run --reporter=json --outputFile=./test-results.json",
    "test:e2e": "playwright test",
    "typecheck": "wrangler types && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@hono/zod-validator": "0.8.0",
    "awilix": "13.0.5",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.26",
    "hono-rate-limiter": "0.5.3",
    "i18next": "26.3.1",
    "isbot": "5.1.43",
    "lucide-react": "1.21.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "react-router": "8.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/vite-plugin": "1.42.1",
    "@cloudflare/vitest-pool-workers": "0.16.18",
    "@playwright/test": "1.61.0",
    "@react-router/dev": "8.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "daisyui": "5.5.23",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  }
}
